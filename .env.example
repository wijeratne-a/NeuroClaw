# Hugging Face (required for gated LLaMA 3.2 weights; shell env overrides this file)
HF_TOKEN=

# Legacy alias (optional)
# HUGGINGFACEHUB_API_TOKEN=

# Memory watermark for staged loader logs (GB)
# MAX_MEMORY_GB=13.5

# Hemodynamic offset stored in artifact metadata (seconds)
# HEMODYNAMIC_OFFSET_S=5.0

# Reproducibility seed
# SEED=42

# Use mock TRIBE + placeholder atlas (CI / offline): 1 or true
# NEUROCLAW_USE_MOCK_TRIBE=1
# NEUROCLAW_PLACEHOLDER_ATLAS=1

# TRIBE version string for metadata
# TRIBEV2_VERSION=0.3.x

# Device label in metadata
# NEUROCLAW_DEVICE=auto

# Skip tribev2 internal uvx/WhisperX; build events with faster-whisper in this env (1/true)
NEUROCLAW_PREFER_LOCAL_ASR=1

# After faster-whisper: model size (tiny, base, small, …)
# NEUROCLAW_ASR_MODEL=base

# ASR device: auto | cpu | cuda (MPS → cpu for faster-whisper)
# NEUROCLAW_ASR_DEVICE=auto

# Append faster-whisper words when tribev2 ASR fails (default on; set 0 to disable)
# NEUROCLAW_LOCAL_ASR_ON_FALLBACK=1
